#!/bin/sh

DOTFILES_DIR="$HOME/dotfiles"

sub_help() {
  echo "Usage: dot <command>"
  echo ""
  echo "Commands:"
  echo "  install   Install packages from Brewfile and Caskfile (initial setup)"
  echo "  update    Update dotfiles, Homebrew packages, Oh My Zsh, and VS Code extensions"
  echo "  health    Check symlinks, required tools, and asdf runtimes"
  echo "  clean     Clean up caches (brew, gem)"
  echo "  edit      Open dotfiles in editor"
  echo "  help      This help message"
}

sub_install() {
  echo "Installing Homebrew packages..."
  brew bundle --file="$DOTFILES_DIR/install/Brewfile"

  echo "Installing cask apps..."
  brew bundle --file="$DOTFILES_DIR/install/Caskfile"
}

sub_update() {
  echo "[1/4] Updating dotfiles..."
  if git -C "$DOTFILES_DIR" diff --quiet && git -C "$DOTFILES_DIR" diff --cached --quiet; then
    git -C "$DOTFILES_DIR" pull
  else
    echo "  Skipping: you have local changes in $DOTFILES_DIR"
  fi

  echo "[2/4] Updating Homebrew..."
  brew update && brew upgrade

  echo "[3/4] Updating Oh My Zsh..."
  "$ZSH/tools/upgrade.sh"

  echo "[4/4] Updating VS Code extensions..."
  cat "$DOTFILES_DIR/install/Codefile" | while read ext; do
    code --install-extension "$ext" --force 2>/dev/null || true
  done

  echo "Done!"
}

sub_health() {
  local ok=1

  _check() {
    local label="$1" result="$2"
    if [ "$result" = "ok" ]; then
      printf "  ✓ %s\n" "$label"
    else
      printf "  ✗ %s (%s)\n" "$label" "$result"
      ok=0
    fi
  }

  echo "Symlinks"
  [ -L "$HOME/.zshrc" ]                && _check ".zshrc"               ok || _check ".zshrc"               "not linked"
  [ -L "$HOME/.tool-versions" ]        && _check ".tool-versions"        ok || _check ".tool-versions"        "not linked"
  [ -L "$HOME/.claude/settings.json" ] && _check "claude/settings.json" ok || _check "claude/settings.json" "not linked"
  [ -L "$HOME/Library/Application Support/Code/User/settings.json" ] && _check "vscode/settings.json" ok || _check "vscode/settings.json" "not linked"

  echo ""
  echo "Tools"
  for cmd in brew git stow asdf code; do
    command -v "$cmd" >/dev/null 2>&1 && _check "$cmd" ok || _check "$cmd" "not found"
  done

  echo ""
  echo "asdf runtimes"
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    name=$(echo "$line" | awk '{print $1}')
    version=$(echo "$line" | awk '{print $2}')
    installed=$(asdf list "$name" 2>/dev/null | grep -F "$version")
    [ -n "$installed" ] && _check "$name $version" ok || _check "$name $version" "not installed"
  done < "$DOTFILES_DIR/runcom/.tool-versions"

  echo ""
  [ "$ok" = "1" ] && echo "All checks passed." || echo "Some checks failed. Run \`dot install\` or \`make link\` to fix."
}

sub_clean() {
  echo "Cleaning Homebrew cache..."
  brew cleanup

  echo "Cleaning gem cache..."
  gem cleanup 2>/dev/null
}

sub_edit() {
  code "$DOTFILES_DIR"
}

case "$1" in
  install) sub_install ;;
  update)  sub_update ;;
  health)  sub_health ;;
  clean)   sub_clean ;;
  edit)    sub_edit ;;
  help)    sub_help ;;
  *)       sub_help ;;
esac
