#!/bin/sh

DOTFILES_DIR="$HOME/dotfiles"

sub_help() {
  echo "Usage: dot <command>"
  echo ""
  echo "Commands:"
  echo "  update    Update dotfiles, Homebrew packages, Oh My Zsh, and VS Code extensions"
  echo "  install   Install packages from Brewfile and Caskfile"
  echo "  clean     Clean up caches (brew, gem)"
  echo "  edit      Open dotfiles in editor"
  echo "  help      This help message"
}

sub_install() {
  echo "Installing Homebrew packages..."
  brew bundle --file="$DOTFILES_DIR/install/Brewfile"

  echo "Installing cask apps..."
  brew bundle --file="$DOTFILES_DIR/install/Caskfile"
}

sub_update() {
  echo "[1/4] Updating dotfiles..."
  if git -C "$DOTFILES_DIR" diff --quiet && git -C "$DOTFILES_DIR" diff --cached --quiet; then
    git -C "$DOTFILES_DIR" pull
  else
    echo "  Skipping: you have local changes in $DOTFILES_DIR"
  fi

  echo "[2/4] Updating Homebrew..."
  brew update && brew upgrade

  echo "[3/4] Updating Oh My Zsh..."
  "$ZSH/tools/upgrade.sh"

  echo "[4/4] Updating VS Code extensions..."
  cat "$DOTFILES_DIR/install/Codefile" | while read ext; do
    code --install-extension "$ext" --force 2>/dev/null || true
  done

  echo "Done!"
}

sub_clean() {
  echo "Cleaning Homebrew cache..."
  brew cleanup

  echo "Cleaning gem cache..."
  gem cleanup 2>/dev/null
}

sub_edit() {
  code "$DOTFILES_DIR"
}

case "$1" in
  install) sub_install ;;
  update)  sub_update ;;
  clean)   sub_clean ;;
  edit)    sub_edit ;;
  help)    sub_help ;;
  *)       sub_help ;;
esac
